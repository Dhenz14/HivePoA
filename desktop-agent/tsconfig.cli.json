{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "outDir": "./dist-cli",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": true,
    "lib": ["ES2020"],
    "types": ["node"]
  },
  "include": [
    "src/main/**/*.ts"
  ],
  "exclude": [
    "src/main/preload.ts",
    "src/main/updater.ts",
    "src/main/index.ts"
  ]
}
